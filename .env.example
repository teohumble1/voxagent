# Sao chép thành .env rồi điền:  cp .env.example .env
# .env đã được .gitignore — KHÔNG commit file .env thật.

# --- LLM (cần ít nhất MỘT) ---
# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Provider mặc định: "anthropic" | "openai" | "ollama" (local, free)
VOXAGENT_PROVIDER=anthropic

# --- LLM local qua Ollama (free, không key, dữ liệu không rời máy) ---
# Đặt VOXAGENT_PROVIDER=ollama ở trên để dùng. Tuỳ chỉnh (không bắt buộc):
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Server bảo mật ---
# Đặt token để bật auth Bearer trên /chat (bỏ trống = dev, không auth)
VOXAGENT_API_TOKEN=

# agent-guard sidecar (https://github.com/teohumble1/agent-guard) — lớp phòng
# thủ thứ 2 out-of-process cho /chat. Chạy: python -m agent_guard.server
# Khi đặt URL: sidecar không phản hồi -> server CHẶN request (fail-closed).
# AGENT_GUARD_URL=http://127.0.0.1:8788

# --- Voice real-time (WS /voice) ---
# Chế độ CLOUD: cần đủ 2 key (Deepgram free $200, ElevenLabs free 10k ký tự/tháng)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# Chế độ LOCAL (không mạng/không key): whisper.cpp + Piper, cần đủ 4 đường dẫn.
# Mặc định ưu tiên local nếu đủ; ép chọn bằng VOICE_PROVIDER=local|cloud.
# WHISPER_BIN=/home/teohumble/voice/whisper.cpp/build/bin/whisper-cli
# WHISPER_MODEL=/home/teohumble/voice/models/ggml-base.bin
# PIPER_BIN=/home/teohumble/voice/piper-venv/bin/piper
# PIPER_MODEL=/home/teohumble/voice/models/vi_VN-vais1000-medium.onnx
# VOICE_PROVIDER=local

# --- Observability (tuỳ chọn) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Cache (tuỳ chọn, dùng khi chạy nhiều node) ---
# REDIS_URL=redis://localhost:6379
