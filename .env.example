# Sao chép thành .env rồi điền:  cp .env.example .env
# .env đã được .gitignore — KHÔNG commit file .env thật.

# --- LLM (cần ít nhất MỘT) ---
# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Provider mặc định: "anthropic" hoặc "openai"
VOXAGENT_PROVIDER=anthropic

# --- Server bảo mật ---
# Đặt token để bật auth Bearer trên /chat (bỏ trống = dev, không auth)
VOXAGENT_API_TOKEN=

# --- Voice real-time (bật WS /voice khi có ĐỦ hai key) ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Observability (tuỳ chọn) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Cache (tuỳ chọn, dùng khi chạy nhiều node) ---
# REDIS_URL=redis://localhost:6379
